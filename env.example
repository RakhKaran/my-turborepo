# ============================================
# Mono Project - Environment Configuration
# ============================================
# Copy this file to .env and update values

# ==========================================
# General
# ==========================================
NODE_ENV=production

# ==========================================
# API Server
# ==========================================
API_PORT=3000
HOST=0.0.0.0

# ==========================================
# JWT Authentication
# ==========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# ==========================================
# MongoDB
# ==========================================
MONGO_PORT=27017
MONGO_DATABASE=workflow
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=Admin@123

# ==========================================
# PostgreSQL (Airflow)
# ==========================================
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# ==========================================
# Airflow
# ==========================================
AIRFLOW_API_PORT=9090
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_EMAIL=admin@mono.local
AIRFLOW_FERNET_KEY=S8p2L4l6g9VQe2pXjC5y7GkWbVtmJf7y2Xqj0CN4UJ0=
AIRFLOW_JWT_SECRET=mono_workflow_project

# ==========================================
# Redis (Optional - for caching)
# ==========================================
REDIS_PORT=6379
REDIS_PASSWORD=mono_redis_password

# ==========================================
# Email (SMTP)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ==========================================
# External Services (Future A2A Integration)
# ==========================================
# BBC Agent Server URL (for A2A protocol)
BBC_A2A_URL=
BBC_AUTH_TOKEN=

# MCP Service URL
MCP_SERVER_URL=

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=info

