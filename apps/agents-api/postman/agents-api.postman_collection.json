    {
      "name": "Create Agent",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"agent_sales_v1\",\n  \"title\": \"Sales Agent\",\n  \"description\": \"Handles sales inquiries\",\n  \"status\": \"active\",\n  \"configFields\": [\n    {\n      \"name\": \"channel_id\",\n      \"label\": \"Channel ID\",\n      \"type\": \"text\",\n      \"required\": true\n    },\n    {\n      \"name\": \"trigger_phrase\",\n      \"label\": \"Trigger Phrase\",\n      \"type\": \"text\",\n      \"required\": false,\n      \"placeholder\": \"Optional - leave empty for all messages\"\n    }\n  ],\n  \"defaultValues\": {\n    \"channel_id\": \"\",\n    \"trigger_phrase\": \"\"\n  },\n  \"execution\": {\n    \"endpoint\": \"https://api.vendor.com/chat/send\",\n    \"method\": \"POST\",\n    \"headers\": {\n      \"Content-Type\": \"application/json\"\n    },\n    \"auth\": {\n      \"type\": \"bearer\",\n      \"credentialRef\": \"cred_sales_prod\"\n    },\n    \"queryParams\": [\n      \"channel_id\"\n    ],\n    \"bodyTemplate\": {\n      \"message\": \"{{input.message}}\",\n      \"trigger_phrase\": \"{{config.trigger_phrase}}\"\n    },\n    \"timeoutMs\": 30000\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/agents",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "agents"
          ]
        }
      }
    },
    {
      "name": "Patch Agent",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Sales Agent v2\",\n  \"status\": \"active\",\n  \"description\": \"Updated description\",\n  \"execution\": {\n    \"endpoint\": \"https://api.vendor.com/chat/send-v2\",\n    \"method\": \"POST\",\n    \"headers\": {\n      \"Content-Type\": \"application/json\"\n    },\n    \"auth\": {\n      \"type\": \"bearer\",\n      \"credentialRef\": \"cred_sales_prod\"\n    },\n    \"queryParams\": [\n      \"channel_id\"\n    ],\n    \"bodyTemplate\": {\n      \"message\": \"{{input.message}}\"\n    },\n    \"timeoutMs\": 30000\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/agents/agent_sales_v1",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "agents",
            "agent_sales_v1"
          ]
        }
